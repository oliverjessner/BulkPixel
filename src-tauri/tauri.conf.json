{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BulkPixel",
    "version": "2.0.1",
    "identifier": "com.oli.bulkpixel",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "BulkPixel",
                "width": 1380,
                "height": 1000,
                "minWidth": 1380,
                "minHeight": 1000,
                "center": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'; worker-src 'none'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "copyright": "Copyright © Oliver Jessner",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
        "fileAssociations": [
            {
                "ext": ["jpg", "jpeg"],
                "mimeType": "image/jpeg",
                "name": "BulkPixel JPEG Image",
                "role": "Editor",
                "rank": "Alternate"
            },
            {
                "ext": ["png"],
                "mimeType": "image/png",
                "name": "BulkPixel PNG Image",
                "role": "Editor",
                "rank": "Alternate"
            },
            {
                "ext": ["webp"],
                "mimeType": "image/webp",
                "name": "BulkPixel WebP Image",
                "role": "Editor",
                "rank": "Alternate"
            },
            {
                "ext": ["avif"],
                "mimeType": "image/avif",
                "name": "BulkPixel AVIF Image",
                "role": "Editor",
                "rank": "Alternate"
            }
        ]
    }
}
