{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BulkPixel",
  "version": "0.1.0",
  "identifier": "com.oli.bulkpixel",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BulkPixel",
        "width": 1380,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © Oliver Jessner",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
