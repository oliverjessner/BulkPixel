{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BulkPixel",
    "version": "1.0.2",
    "identifier": "com.oli.bulkpixel",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "BulkPixel",
                "width": 1380,
                "height": 960,
                "minWidth": 1100,
                "minHeight": 760,
                "center": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'; worker-src 'none'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "copyright": "Copyright © Oliver Jessner",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    }
}
